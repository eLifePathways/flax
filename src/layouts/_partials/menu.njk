<aside class="topbar">
        {% include "_partials/logo.njk" %}
    <nav>
        <ul>
            {% for cmsPage in (cmsPages.pages | reorderPages) %}
                {% if cmsPage.menu == true or cmsPage.menu == "true" %}
                    <li>
                        <a 
                        class="{% if cmsPage.url == page.url %}active{% endif %}" 
                        href="{{cmsPage.url}}"
                        title="{{ cmsPage.title }}">
                        {{ cmsPage.title }}
                        </a>
                    </li>
                {% endif %}
            {% endfor %}
        </ul>
    </nav>
</aside>