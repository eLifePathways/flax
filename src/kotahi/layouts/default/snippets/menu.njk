<aside class="topbar">
    <a href="/">
        {# {% include "snippets/logo.njk" %} #}
        {{ config.group.name }}
    </a>
    <nav>
        <ul>
            {% for cmsHeaderPage in (cmsLayout.flaxHeaderConfig | reorderPages) %}
                {% if cmsHeaderPage.shownInMenu == true or cmsHeaderPage.shownInMenu == "true" %}
                    <li>
                        <a href="{{ cmsHeaderPage.url }}" title="{{ cmsHeaderPage.title }}">{{ cmsHeaderPage.title }}</a>
                    </li>
                {% endif %}
            {% endfor %}
            <li>
                <a href="submit" title="Submit to ">Submit</a>
            </li>
        </ul>
    </nav>
</aside>
