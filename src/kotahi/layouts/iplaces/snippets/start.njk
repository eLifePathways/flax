<!DOCTYPE html>
<html lang="{% if lang %}{{ lang }}{% else %} {{ site.lang }}{% endif %}"
      class="no-js">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width">
        <title>
            {% if title %}
                {{ site.name }}
            {% else %}
                {{ site.name }}
            {% endif %}
        </title>
        <script type="module">
            document
                .documentElement
                .classList
                .remove('no-js');
            document
                .documentElement
                .classList
                .add('js');
        </script>
        <meta name="description" content="{{ site.description }}">
        <meta property="og:title" content="{{ title }}">
        <meta property="og:description"
              content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
        <meta property="og:image" content="{{ site.image }}">
        <meta property="og:image:alt" content="{{ site.imageAlt }}">
        <meta property="og:locale" content="{{ site.locale }}">
        <meta property="og:type" content="website">
        <meta name="twitter:card" content="summary_large_image">
        <meta property="og:url" content="site.url">
        {% if cmsLayout.favicon %}
            <link rel="icon"
                  href="{{ config.defaultImagesDirectory }}/favicon.png?{{ cmsLayout.favicon.id }}">
        {% endif %}
        <meta name="twitter:dnt" content="on">
        {% block styles %}
            <link rel="stylesheet"
                  href="/{% if cmsLayout.hexCode %}{{ cmsLayout.hexCode }}/{% endif %}assets/css/main.css?{{ [1,2,3,4,5,6,7,8,9] | random }}{{ [1,2,3,4,5,6,7,8,9] | random }}{{ [1,2,3,4,5,6,7,8,9] | random }}">
        {% endblock %}
        <style>
:root {
    --color-journal-main:  #41a49f;
    --color-journal-background:  #b3f0ed;
    --color-journal-background-dark: #077b7b;
}
        </style>
    </head>
