{% extends '../layouts/base.njk' %}
{% set currentPage = article %}
{% set title = article.meta.title %}
{% block content %}
    <main>
        <div class="article-preview-header">
            <span class="topics"> {{article.parsedSubmission.topics | arrayToString}}  </span>
            <span class="article-title"> {{article.meta.title}}</span>
             <ul class="authors metadata">
                {% for author in article.parsedSubmission.authorNames %}
                    <li class="author metadata">
                        <span class="author-name">{{- author.firstName -}}&nbsp;{{- author.lastName -}}</span>
                        {% if author.email %}
                            <a class="email" href="mailto:{{ author.email }}">{% include "_partials/icon-email.njk" %}</a>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
            <ul class="authors">
                {% for author in article.parsedSubmission.authorNames %}
                    <li class="author metadata">
                        <span class="author-affiliation">{{article.parsedSubmission.authorNames | arrayToString('affiliation')}}</span>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </main>
{% endblock %}
{% block side %}{# nothing  #}{% endblock %}
