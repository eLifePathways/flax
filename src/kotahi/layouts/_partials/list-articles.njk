<section class="articles-list">
    {% if articleQuery.articles.length == 0 %}
        No articles published yet.
    {% endif %}

    {% for article in pagination.items %}
        <article>
            <span class="topics"> {{article.parsedSubmission.topics | arrayToString}}  </span>
            <h2 class="article-title">
                <a href="/articles/{{article.shortId}}/index.html">{{article.meta.title}}</a>
            </h2>

            <span class="author-name">{{article.parsedSubmission.authorNames | arrayToString('lastName')}}</span>
            <p class="published-date">
                Published on <time datetime="article.publishedDate">{{ article.publishedDate | replace('Z','') | postDate }}</time>
            </p>
            
        </article>
{% endfor %}
</section>

{% if pagination.pages.length > 1 %}
    <div class="pagination-page">
        {% include "_partials/article-page-links.njk" %}
    </div>
{% endif %}

