<div class="partnersTopContainer">
    <div class="partners-file-container">
        {% for partner in (cmsLayout.partners | reorderPages) %}
            <div class="partner-file-item">
                <div class="partner-file">
                    <a href="{{ partner.url }}" target="_blank"> 
                        <img src={{partner.image.imageLocalUrl}} />
                    </a>
                </div>
                
            </div>
        {% endfor %}
    </div>
</div>