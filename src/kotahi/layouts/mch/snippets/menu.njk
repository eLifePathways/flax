<aside class="topbar">
    <section class="top-division">
        <a class="logo" href="/">{% include "./logo.njk" %}</a>
        {# journal intro #}
        <div class="journalmeta">
            <p class="journaltitle">Material Chemistry Horizon</p>
            <ul class="labels">
                {# <li class="label">Cite Score <span class="score">10.1</span></li> #}
                {# <li class="label">Impact factor <span class="score">10.1</span></li> #}
                <li class="logo-open-access">
                    {% include "./icons/openaccess.njk" %}
                    Open Access
                </li>
            </ul>
        </div>
        <div class="cover">
            <img src="/assets/images/mch/cover1.jpg" alt="">
        </div>
    </section>
    <nav>
        <ul>
            {% for cmsHeaderPage in (cmsLayout.flaxHeaderConfig | reorderPages) %}
                {% if cmsHeaderPage.shownInMenu == true or cmsHeaderPage.shownInMenu == "true" %}
                    <li>
                        <a href="{{ cmsHeaderPage.url }}" title="{{ cmsHeaderPage.title }}">{{ cmsHeaderPage.title }}</a>
                    </li>
                {% endif %}
            {% endfor %}
            {# <li> #}
            {#     <a href="/issues/">issues list</a> #}
            {# </li> #}
            <li>
                <a href="/articles/1/">article single</a>
            </li>
            <li class="submit">
                <a href="#submit">submit your manuscript</a>
            </li>
            {# <input class="search" type="text" placeholder="Search…"> #}
        </ul>
    </nav>
</aside>
