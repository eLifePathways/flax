{% block scripts %}
    <script>
    document.querySelectorAll("#home-part3 details").forEach(detail =>{
        detail.addEventListener("click", function(event) {
            document.querySelector("#home-part3 details[open]")?.removeAttribute("open");
        })
    })
    </script>
{% endblock %}
